<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:         #0A0F14;
  --bg-alt:     #0F161D;
  --surface:    #141C24;
  --surface-2:  #1B2530;
  --line:       rgba(255,255,255,0.08);
  --line-2:     rgba(255,255,255,0.12);
  --text:       #E8ECEF;
  --text-dim:   #9AA5B1;
  --text-mute:  #6B7680;
  --accent:     #22BDEF;
  --accent-dim: rgba(34,189,239,0.15);
  --accent-soft:rgba(34,189,239,0.08);
  --green:      #22C55E;
  --red:        #EF4444;
  --font:       'IBM Plex Sans', system-ui, sans-serif;
  --mono:       'IBM Plex Mono', monospace;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}

/* Subtle radial glow */
body::before {
  content: '';
  position: fixed;
  top: -20%; left: 50%; transform: translateX(-50%);
  width: 1200px; height: 700px;
  background: radial-gradient(ellipse at center, rgba(34,189,239,0.08) 0%, transparent 60%);
  pointer-events: none; z-index: 0;
}

/* ── NAV ─────────────────────────────────────────────────────────── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.1rem 2.5rem;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(10,15,20,0.82);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--line);
}
.logo {
  font-family: var(--font);
  font-weight: 600;
  font-size: 0.92rem;
  color: var(--text);
  letter-spacing: -0.01em;
  display: flex; align-items: center; gap: 0.5rem;
}
.logo-mark { color: var(--accent); }
.nav-meta {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--text-mute);
  letter-spacing: 0.02em;
}

/* ── WRAPPER ─────────────────────────────────────────────────────── */
.container {
  position: relative; z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* ── HERO ────────────────────────────────────────────────────────── */
.hero {
  padding: 7.5rem 2rem 5rem;
  position: relative; z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
}

/* Industry pill / callout */
.industry-box {
  display: inline-flex; align-items: center; gap: 0.6rem;
  padding: 0.55rem 0.95rem;
  background: var(--accent-soft);
  border: 1px solid rgba(34,189,239,0.25);
  border-radius: 100px;
  margin-bottom: 1.75rem;
  opacity: 0; animation: up 0.5s 0.05s forwards;
}
.industry-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12px var(--accent);
  animation: pulse 2s infinite;
}
.industry-text {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: var(--accent);
  text-transform: uppercase;
  font-weight: 500;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.eyebrow {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--text-mute);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 1rem;
  opacity: 0; animation: up 0.5s 0.1s forwards;
}

h1 {
  font-size: clamp(2rem, 4vw, 3.4rem);
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.025em;
  color: var(--text);
  margin-bottom: 1.25rem;
  max-width: 800px;
  opacity: 0; animation: up 0.55s 0.15s forwards;
}
h1 em {
  font-style: italic;
  color: var(--accent);
  font-weight: 500;
}

.lede {
  font-size: clamp(0.95rem, 1.4vw, 1.1rem);
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.6;
  max-width: 620px;
  margin-bottom: 2.5rem;
  opacity: 0; animation: up 0.55s 0.22s forwards;
}

/* Hero form */
.hero-form {
  max-width: 520px;
  opacity: 0; animation: up 0.55s 0.3s forwards;
}
.hero-form-label {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: var(--text-mute);
  text-transform: uppercase;
  margin-bottom: 0.65rem;
}

/* Stats row */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  margin-top: 3.5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--line);
  opacity: 0; animation: up 0.6s 0.4s forwards;
}
.stat {
  padding: 0 1.25rem;
  border-right: 1px solid var(--line);
}
.stat:first-child { padding-left: 0; }
.stat:last-child { border-right: none; padding-right: 0; }
.stat-num {
  font-family: var(--font);
  font-size: 1.8rem;
  font-weight: 500;
  color: var(--accent);
  line-height: 1;
  margin-bottom: 0.4rem;
  letter-spacing: -0.02em;
}
.stat-label {
  font-size: 0.78rem;
  color: var(--text-dim);
  line-height: 1.45;
}

/* ── SECTION ─────────────────────────────────────────────────────── */
section.block {
  padding: 5rem 2rem;
  border-top: 1px solid var(--line);
  position: relative; z-index: 1;
}
.block-inner {
  max-width: 1100px;
  margin: 0 auto;
}

.section-tag {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  color: var(--text-mute);
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex; align-items: center; gap: 0.6rem;
}
.section-tag-num {
  color: var(--accent);
}
h2 {
  font-size: clamp(1.7rem, 2.8vw, 2.4rem);
  font-weight: 500;
  letter-spacing: -0.02em;
  line-height: 1.15;
  color: var(--text);
  margin-bottom: 1rem;
  max-width: 720px;
}
h2 em { font-style: italic; color: var(--accent); font-weight: 400; }
.section-sub {
  font-size: 1rem;
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.65;
  max-width: 620px;
  margin-bottom: 3rem;
}

/* ── SOCIAL PROOF ────────────────────────────────────────────────── */
.proof-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  border-radius: 8px;
  overflow: hidden;
}
.proof-card {
  background: var(--surface);
  padding: 2rem;
  display: flex; flex-direction: column; gap: 0.75rem;
  transition: background 0.2s;
}
.proof-card:hover { background: var(--surface-2); }
.proof-num {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  color: var(--accent);
  text-transform: uppercase;
  font-weight: 500;
}
.proof-title {
  font-size: 1.15rem;
  font-weight: 500;
  color: var(--text);
  line-height: 1.3;
  letter-spacing: -0.01em;
}
.proof-desc {
  font-size: 0.9rem;
  color: var(--text-dim);
  line-height: 1.6;
  font-weight: 300;
}
.proof-icon {
  width: 36px; height: 36px;
  border-radius: 4px;
  background: var(--accent-soft);
  border: 1px solid rgba(34,189,239,0.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--accent);
  font-family: var(--mono);
  font-size: 0.9rem;
  font-weight: 500;
  margin-bottom: 0.25rem;
}

/* ── WHO IT'S FOR ────────────────────────────────────────────────── */
.for-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  border-radius: 8px;
  overflow: hidden;
}
.for-card {
  background: var(--surface);
  padding: 2rem 1.75rem;
  transition: background 0.2s;
}
.for-card:hover { background: var(--surface-2); }
.for-title {
  font-size: 1.05rem;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 0.6rem;
  letter-spacing: -0.01em;
}
.for-desc {
  font-size: 0.9rem;
  color: var(--text-dim);
  line-height: 1.6;
  font-weight: 300;
}

/* "Not for you" note */
.not-for {
  margin-top: 2rem;
  padding: 1.5rem 1.75rem;
  background: transparent;
  border: 1px dashed var(--line-2);
  border-radius: 6px;
}
.not-for-label {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: var(--text-mute);
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}
.not-for-text {
  font-size: 0.9rem;
  color: var(--text-dim);
  line-height: 1.65;
  font-weight: 300;
}

/* ── WHY / BULLETS ──────────────────────────────────────────────── */
.why-list {
  list-style: none;
  display: grid;
  gap: 1.25rem;
  max-width: 820px;
}
.why-item {
  display: flex; gap: 1.25rem;
  align-items: flex-start;
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--line);
}
.why-item:last-child { border-bottom: none; }
.why-num {
  font-family: var(--mono);
  font-size: 0.78rem;
  color: var(--accent);
  font-weight: 500;
  padding-top: 3px;
  min-width: 28px;
  letter-spacing: 0.02em;
}
.why-text {
  font-size: 1rem;
  color: var(--text);
  line-height: 1.65;
  font-weight: 400;
}
.why-text strong {
  color: var(--text);
  font-weight: 600;
}

/* ── FINAL CTA ──────────────────────────────────────────────────── */
.cta-block {
  padding: 6rem 2rem 7rem;
  border-top: 1px solid var(--line);
  text-align: center;
  position: relative; z-index: 1;
  background: linear-gradient(180deg, transparent 0%, rgba(34,189,239,0.02) 100%);
}
.cta-inner {
  max-width: 620px;
  margin: 0 auto;
}
.cta-title {
  font-size: clamp(1.8rem, 3.2vw, 2.6rem);
  font-weight: 500;
  letter-spacing: -0.025em;
  line-height: 1.15;
  margin-bottom: 1rem;
}
.cta-title em { font-style: italic; color: var(--accent); font-weight: 400; }
.cta-sub {
  font-size: 1rem;
  font-weight: 300;
  color: var(--text-dim);
  line-height: 1.65;
  margin-bottom: 2.5rem;
}
.cta-form-label {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  color: var(--text-mute);
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}
.cta-form-wrap {
  max-width: 440px;
  margin: 0 auto;
  text-align: left;
}

/* ── FOOTER ─────────────────────────────────────────────────────── */
footer {
  border-top: 1px solid var(--line);
  padding: 2rem;
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--text-mute);
  letter-spacing: 0.02em;
  position: relative; z-index: 1;
}
.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}
footer a {
  color: var(--text-dim);
  text-decoration: none;
  transition: color 0.2s;
}
footer a:hover { color: var(--accent); }

/* ── HUBSPOT FORM THEMING ───────────────────────────────────────── */
.hs-form-frame { width: 100%; }

.hs-form,
.hs-form * {
  font-family: var(--font) !important;
  box-sizing: border-box !important;
}

.hs-form .hs-form-field {
  margin-bottom: 0.9rem !important;
}

.hs-form .hs-form-field > label,
.hs-form label.hs-form-field,
.hs-form .hs-field-desc {
  font-family: var(--mono) !important;
  font-size: 0.7rem !important;
  font-weight: 500 !important;
  letter-spacing: 0.06em !important;
  text-transform: uppercase !important;
  color: var(--text-mute) !important;
  margin-bottom: 0.4rem !important;
  display: block !important;
}

.hs-form input[type="text"],
.hs-form input[type="email"],
.hs-form input[type="tel"],
.hs-form input[type="number"],
.hs-form select,
.hs-form textarea {
  font-family: var(--font) !important;
  font-size: 0.92rem !important;
  font-weight: 400 !important;
  color: var(--text) !important;
  background: var(--surface) !important;
  border: 1px solid var(--line-2) !important;
  border-radius: 5px !important;
  padding: 0.75rem 0.95rem !important;
  width: 100% !important;
  outline: none !important;
  transition: border-color 0.2s, background 0.2s !important;
  -webkit-appearance: none !important;
  line-height: 1.4 !important;
}

.hs-form input::placeholder { color: var(--text-mute) !important; opacity: 0.7 !important; }

.hs-form input:focus,
.hs-form select:focus,
.hs-form textarea:focus {
  border-color: var(--accent) !important;
  background: var(--surface-2) !important;
  box-shadow: 0 0 0 3px rgba(34,189,239,0.1) !important;
}

.hs-form select option { background: var(--surface) !important; color: var(--text) !important; }

/* Submit button */
.hs-form input[type="submit"],
.hs-form .hs-button,
.hs-form button[type="submit"] {
  font-family: var(--font) !important;
  font-size: 0.92rem !important;
  font-weight: 500 !important;
  letter-spacing: 0.01em !important;
  color: var(--bg) !important;
  background: var(--accent) !important;
  border: none !important;
  border-radius: 5px !important;
  padding: 0.85rem 1.75rem !important;
  width: 100% !important;
  cursor: pointer !important;
  transition: background 0.2s, transform 0.1s !important;
  margin-top: 0.5rem !important;
}
.hs-form input[type="submit"]:hover,
.hs-form .hs-button:hover,
.hs-form button[type="submit"]:hover {
  background: #3EC9F2 !important;
}
.hs-form input[type="submit"]:active,
.hs-form .hs-button:active {
  transform: translateY(1px) !important;
}

/* Checkbox & consent text */
.hs-form .hs-form-booleancheckbox label,
.hs-form .legal-consent-container,
.hs-form .legal-consent-container *,
.hs-form .hs-richtext,
.hs-form .hs-richtext *,
.hs-form p {
  font-family: var(--font) !important;
  font-size: 0.75rem !important;
  font-weight: 400 !important;
  color: var(--text-mute) !important;
  letter-spacing: 0 !important;
  text-transform: none !important;
  line-height: 1.55 !important;
}
.hs-form .hs-richtext a,
.hs-form .legal-consent-container a,
.hs-form a {
  color: var(--accent) !important;
  text-decoration: none !important;
}
.hs-form .hs-richtext a:hover,
.hs-form a:hover { text-decoration: underline !important; }

.hs-form .hs-form-booleancheckbox input[type="checkbox"],
.hs-form input[type="checkbox"] {
  accent-color: var(--accent) !important;
  width: 14px !important; height: 14px !important;
  margin-right: 0.5rem !important;
  flex-shrink: 0 !important;
  margin-top: 3px !important;
}

.hs-form .inputs-list { list-style: none !important; padding: 0 !important; margin: 0 !important; }
.hs-form .inputs-list li {
  display: flex !important; align-items: flex-start !important;
  gap: 0.5rem !important; margin: 0 !important;
}
.hs-form .legal-consent-container .hs-form-booleancheckbox-display {
  display: flex !important; align-items: flex-start !important;
}

/* Error messages */
.hs-form .hs-error-msg,
.hs-form .hs-error-msgs li,
.hs-form .hs-error-msgs {
  font-family: var(--font) !important;
  font-size: 0.75rem !important;
  color: var(--red) !important;
  margin-top: 0.35rem !important;
  list-style: none !important;
  font-weight: 400 !important;
  letter-spacing: 0 !important;
  text-transform: none !important;
}

/* Submitted message */
.submitted-message,
.hs-form .submitted-message {
  font-family: var(--font) !important;
  font-size: 0.95rem !important;
  color: var(--accent) !important;
  text-align: left !important;
  padding: 1rem 1.25rem !important;
  background: var(--accent-soft) !important;
  border: 1px solid rgba(34,189,239,0.2) !important;
  border-radius: 5px !important;
  line-height: 1.55 !important;
}

/* ── ANIMATIONS ─────────────────────────────────────────────────── */
@keyframes up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: none; }
}
.reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.55s, transform 0.55s; }
.reveal.in { opacity: 1; transform: none; }
.d1 { transition-delay: 0.05s; }
.d2 { transition-delay: 0.12s; }
.d3 { transition-delay: 0.2s; }
.d4 { transition-delay: 0.28s; }

/* ── RESPONSIVE ─────────────────────────────────────────────────── */
@media (max-width: 820px) {
  .proof-grid, .for-grid { grid-template-columns: 1fr; }
  .stats-row { grid-template-columns: 1fr 1fr; gap: 1.5rem 0; }
  .stat { padding: 0.75rem 1rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .stat:nth-child(2n) { border-right: none; }
  .stat:nth-last-child(-n+2) { border-bottom: none; }
  .stat:first-child { padding-left: 1rem; }
  .stat:last-child { padding-right: 1rem; }
  .hero { padding: 6rem 1.5rem 3.5rem; }
  section.block, .cta-block { padding: 3.5rem 1.5rem; }
  nav { padding: 1rem 1.5rem; }
  .nav-meta { display: none; }
}
</style>
